# ─────────────────────────────────────────────────────────────────────────────
# World / Tools for Humanity — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Provided automatically by Replit on deploy.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worldtfh_dev

# Decomposed alternatives (used by some tools like drizzle-kit):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=worldtfh_dev

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express server listens on (set automatically by the Replit runtime).
PORT=8080

# Comma-separated list of origins allowed by CORS in production.
# In development, all localhost origins are allowed automatically.
ALLOWED_ORIGINS=https://your-app.replit.app

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base path for the Vite app (set automatically by the Replit runtime).
BASE_PATH=/

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Session / Security ────────────────────────────────────────────────────────
# A strong random secret used for session signing (if you add auth later).
SESSION_SECRET=change-me-to-a-random-64-character-string
